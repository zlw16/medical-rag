# 医疗RAG系统配置示例
# 复制此文件为 .env 并填入真实配置

# LLM配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 服务器配置
SERVER_HOST=127.0.0.1
SERVER_PORT=5001

# 检索配置
TOP_K=5
TFIDF_WEIGHT=0.3
BM25_WEIGHT=0.4

# 增强检索配置
SEMANTIC_WEIGHT=0.3
USE_SYNONYMS=true
USE_QUERY_REWRITE=true

# 文档配置
DOC_FOLDER=./medical_knowledge
CACHE_FOLDER=./cache
LOG_FOLDER=./logs
