# 医疗RAG系统配置示例
# 复制此文件为 .env 并填入真实配置

# LLM配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 服务器配置
SERVER_HOST=127.0.0.1
SERVER_PORT=5001

# 检索配置（BM25关键词 + BGE语义双通道）
TOP_K=10
BM25_WEIGHT=0.5
SEMANTIC_WEIGHT=0.5

# 增强检索配置
USE_SYNONYMS=true
USE_QUERY_REWRITE=true
USE_RERANKER=true

# Milvus向量检索
USE_MILVUS=false
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 文档配置
DOC_FOLDER=./medical_knowledge
CACHE_FOLDER=./cache
LOG_FOLDER=./logs
